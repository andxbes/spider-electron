{
  "name": "spider-electron",
  "version": "1.0.0",
  "description": "A simple web spider built with Electron",
  "author": "andxbes",
  "main": "src/main/main.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "build:css": "postcss ./src/renderer/input.css -o ./src/renderer/styles.css",
    "start": "npm run build:css && CI=true electron-forge start",
    "prepackage": "npm run build:css",
    "package": "CI=true electron-forge package",
    "premake": "npm run build:css",
    "make": "CI=true electron-forge make",
    "make:linux": "CI=true electron-forge make --platform=linux",
    "linux": "npm run make:linux",
    "make:win": "CI=true electron-forge make --platform=win32",
    "make:mac": "CI=true electron-forge make --platform=darwin",
    "test": "node --test tests/**/*.test.js"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@tailwindcss/postcss": "^4.3.0",
    "electron": "42.3.3",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "robots-parser": "^3.0.1"
  }
}
